{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mission-planer.local/schemas/schema_registry.json",
  "title": "SatelliteSchemaRegistry",
  "description": "Version routing inventory only. Maps schema_version + document kind to schema file paths under schemas/, and lists canonical type schemas. Does not encode runtime policy, negotiation, or fallback rules.",
  "versions": {
    "1.0": {
      "envelope": "task_envelope.schema.json",
      "result": "task_result.schema.json",
      "manifest": "plugin_manifest.schema.json"
    },
    "1.1": {
      "envelope": "task_envelope.1.1.schema.json",
      "result": "task_result.1.1.schema.json",
      "manifest": "plugin_manifest.1.1.schema.json"
    }
  },
  "canonical": {
    "TimeWindow": "canonical/time_window.schema.json",
    "WindowSet": "canonical/window_set.schema.json",
    "GeoPoint": "common/geo_point.schema.json",
    "Receiver": "common/receiver.schema.json",
    "DataProduct": "canonical/data_product.schema.json",
    "DeliveryReceipt": "canonical/delivery_receipt.schema.json",
    "ImageMeta": "canonical/image_meta.schema.json",
    "ImageMetaSet": "canonical/image_meta_set.schema.json",
    "CostScore": "canonical/cost_score.schema.json",
    "PolicyDecision": "canonical/policy_decision.schema.json"
  }
}
