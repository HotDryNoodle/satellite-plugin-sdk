{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mission-planer.local/schemas/plugin_manifest.1.1.schema.json",
  "title": "PluginManifest11",
  "description": "Active schema_version=1.1 plugin manifest. Adds capabilities.kind and side-effect semantics. Historical 1.0 manifests are under schemas/archive/1.0/ and are not on the active registry route.",
  "type": "object",
  "required": ["schema_version", "name", "executable", "version", "commands", "capabilities"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1" },
    "name": { "type": "string", "minLength": 1 },
    "executable": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "domain": {
      "type": "string",
      "description": "Satellite subsystem domain, e.g. mission, image, telemetry"
    },
    "safety_class": {
      "type": "string",
      "enum": ["planning_only", "command_reversible", "command_irreversible"]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["manifest", "validate", "run", "status", "cancel"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "scenarios": {
      "type": "array",
      "items": { "type": "string" }
    },
    "input_schema_path": { "type": "string" },
    "output_schema_path": { "type": "string" },
    "capabilities": {
      "type": "object",
      "required": [
        "kind",
        "side_effect_class",
        "relocatable",
        "deterministic",
        "idempotent",
        "retryable",
        "consumes",
        "produces"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["compute", "query", "policy", "actuate", "transport", "deliver"]
        },
        "side_effect_class": {
          "type": "string",
          "enum": ["none", "read_only", "reversible", "irreversible", "external_delivery"]
        },
        "relocatable": { "type": "boolean" },
        "deterministic": { "type": "boolean" },
        "idempotent": { "type": "boolean" },
        "retryable": { "type": "boolean" },
        "consumes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "produces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hardware_tag": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "timeout_sec": { "type": "integer", "minimum": 1 },
        "compensation": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "cost_hint": {
          "type": "object",
          "properties": {
            "typical_latency_sec": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "async": { "type": "boolean" },
        "dry_run": { "type": "boolean" },
        "cancel": { "type": "string", "enum": ["process_signal", "none"] },
        "requires_gmat": { "type": "boolean" },
        "requires_hardware": { "type": "boolean" },
        "batch": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "resource_limits": {
      "type": "object",
      "properties": {
        "timeout_sec": { "type": "integer", "minimum": 1 },
        "max_parallel": { "type": "integer", "minimum": 1 },
        "max_work_dir_mb": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "agent_hints": {
      "type": "object",
      "properties": {
        "when_to_use": { "type": "string" },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "typical_latency_sec": { "type": "integer", "minimum": 0 },
        "compose_with": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
